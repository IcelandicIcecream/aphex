{
	"name": "@aphexcms/auth",
	"version": "15.0.1",
	"license": "MIT",
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/IcelandicIcecream/aphex.git",
		"directory": "packages/auth"
	},
	"type": "module",
	"main": "./src/index.js",
	"types": "./src/index.d.ts",
	"exports": {
		".": {
			"types": "./src/index.d.ts",
			"import": "./src/index.js",
			"default": "./src/index.js"
		},
		"./schema/pg": {
			"types": "./src/schema/pg.d.ts",
			"import": "./src/schema/pg.js",
			"default": "./src/schema/pg.js"
		},
		"./schema/sqlite": {
			"types": "./src/schema/sqlite.d.ts",
			"import": "./src/schema/sqlite.js",
			"default": "./src/schema/sqlite.js"
		}
	},
	"files": [
		"src",
		"CHANGELOG.md"
	],
	"scripts": {
		"build": "tsc",
		"dev:local": "node ../../scripts/swap-package-paths.js ./package.json src",
		"prepack": "node ../../scripts/swap-package-paths.js ./package.json dist",
		"postpack": "node ../../scripts/swap-package-paths.js ./package.json src"
	},
	"dependencies": {
		"@aphexcms/cms-core": "workspace:^",
		"@better-auth/api-key": "^1.5.3",
		"better-auth": "^1.5.3",
		"drizzle-orm": "^0.45.2"
	},
	"peerDependencies": {
		"@aphexcms/cms-core": "workspace:^"
	},
	"devDependencies": {
		"@aphexcms/cms-core": "workspace:^",
		"typescript": "^5.9.3"
	}
}
