{
	"name": "create-aphex",
	"version": "0.1.3",
	"description": "Scaffold a new Aphex CMS project — invoked via `pnpm create aphex`",
	"publishConfig": {
		"provenance": true
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/IcelandicIcecream/aphex.git",
		"directory": "packages/create-aphex"
	},
	"type": "module",
	"bin": {
		"create-aphex": "./dist/index.js"
	},
	"files": [
		"dist",
		"templates"
	],
	"scripts": {
		"build": "node scripts/copy-templates.js && tsc",
		"prepublishOnly": "pnpm build"
	},
	"keywords": [
		"aphex",
		"cms",
		"cli",
		"scaffolding",
		"template"
	],
	"author": "",
	"license": "MIT",
	"dependencies": {
		"@clack/prompts": "^0.11.0",
		"picocolors": "^1.1.1"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"typescript": "^5.9.3"
	}
}
