{
	"name": "@aphexcms/postgresql-adapter",
	"version": "14.3.0",
	"description": "PostgreSQL database adapter for Aphex CMS using Drizzle ORM",
	"license": "MIT",
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/IcelandicIcecream/aphex.git",
		"directory": "packages/postgresql-adapter"
	},
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./schema": {
			"types": "./dist/schema.d.ts",
			"import": "./dist/schema.js",
			"default": "./dist/schema.js"
		},
		"./pglite": {
			"types": "./dist/pglite.d.ts",
			"import": "./dist/pglite.js",
			"default": "./dist/pglite.js"
		}
	},
	"files": [
		"dist",
		"CHANGELOG.md"
	],
	"scripts": {
		"build": "tsc && node ../../scripts/fix-imports.js ./dist",
		"dev": "tsc --watch",
		"prepublishOnly": "pnpm build",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.2",
		"postgres": "^3.4.7"
	},
	"peerDependencies": {
		"@aphexcms/cms-core": "workspace:^",
		"@electric-sql/pglite": "^0.5.0"
	},
	"peerDependenciesMeta": {
		"@electric-sql/pglite": {
			"optional": true
		}
	},
	"devDependencies": {
		"@aphexcms/cms-core": "workspace:^",
		"@electric-sql/pglite": "^0.5.0",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3"
	}
}
