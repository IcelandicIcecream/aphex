{
	"name": "@aphexcms/storage-s3",
	"version": "2.0.0",
	"description": "S3-compatible storage adapter for Aphex CMS (AWS S3, Cloudflare R2, MinIO, etc.)",
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/IcelandicIcecream/aphex.git",
		"directory": "packages/storage-s3"
	},
	"type": "module",
	"main": "./src/index.js",
	"types": "./src/index.d.ts",
	"exports": {
		".": {
			"types": "./src/index.d.ts",
			"import": "./src/index.js",
			"default": "./src/index.js"
		}
	},
	"files": [
		"src"
	],
	"scripts": {
		"build": "tsc",
		"dev:local": "node ../../scripts/swap-package-paths.js ./package.json src",
		"prepack": "node ../../scripts/swap-package-paths.js ./package.json dist",
		"postpack": "node ../../scripts/swap-package-paths.js ./package.json src"
	},
	"dependencies": {
		"s3mini": "^0.7.0"
	},
	"peerDependencies": {
		"@aphexcms/cms-core": "workspace:*"
	},
	"devDependencies": {
		"@aphexcms/cms-core": "workspace:*",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3"
	}
}
