# ============================
# Database Configuration
# ============================

## Option (0): Embedded pglite (zero infra — no Docker/Postgres needed)
## -------------------------------------------------------------------
## Set APHEX_DATABASE=pglite to run on an in-process Postgres persisted to a local folder.
## First run `aphex migrate` to create the tables, then `pnpm dev`.
# APHEX_DATABASE=pglite
# APHEX_PGLITE_DIR=.aphex/pgdata   # default; gitignored

## Option (0b): SQLite via libsql (zero infra — no Docker, no migrations)
## ----------------------------------------------------------------------
## The fastest way to run studio: the schema is pushed on boot, so `pnpm dev` is
## all you need. Set APHEX_SQLITE_URL to a libsql:// URL to run against Turso.
# APHEX_DATABASE=sqlite
# APHEX_SQLITE_URL=file:.aphex/studio.db   # default; gitignored
# DATABASE_AUTH_TOKEN=                      # required for Turso (libsql://) only

## Option (1): Using a full DATABASE_URL
## -------------------------------------
DATABASE_URL="postgres://root:my-secret-password@localhost:5432/local"

## Option (2): Using individual connection settings
## -----------------------------------------------
## Uncomment and set these if not using DATABASE_URL
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=root
# PG_PASSWORD=my-secret-password
# PG_DATABASE=local

## Boot-migrate (all drivers)
## -------------------------
## By default the schema is migrated/pushed on boot so `pnpm dev` just works. In
## production with multiple app replicas, prefer migrating as a separate deploy
## step (init container / CI job before rollout) and disable boot-migrate here.
## When off, run `pnpm db:migrate` yourself. Accepts false/0/no/off.
# APHEX_DB_AUTO_MIGRATE=false

## Plugin secret settings
## ---------------------
## Encrypts plugin `secret` settings fields at rest (AES-256-GCM). Use a long,
## random string (32+ chars) and keep it stable across deploys — rotating it makes
## existing encrypted secrets undecryptable. When unset, secret fields are disabled
## (read-only) rather than stored as plaintext. Generate one with:
##   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# APHEX_SECRET_ENCRYPTION_KEY=

# ============================
# Auth Configuration
# ============================
# BETTER_AUTH_SECRET / BETTER_AUTH_URL also work for backwards compatibility
BETTER_AUTH_SECRET=your-secret-key-here-change-in-production
BETTER_AUTH_URL=http://localhost:5173
AUTH_TRUSTED_ORIGINS=http://localhost:5173

## Email verification is DISABLED by default, so the first signup can log in
## immediately without an SMTP/Mailpit server. Opt in with `true` — recommended
## in production, since without it anyone can sign up with an address they don't
## own (and the first user becomes super admin).
# AUTH_REQUIRE_EMAIL_VERIFICATION=true

# ============================
# Resend Email Configuration (optional)
# ============================
RESEND_API_KEY=re_your_api_key_here

# ============================
# S3_COMPATIBLE CONFIGURATION (optional)
# ============================
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
# Optional: custom CDN domain (overrides R2_PUBLIC_URL for asset URLs)
# R2_CDN_URL=https://cdn.yourdomain.com

# ============================
# Vercel Blob Storage (optional)
# ============================
## Set automatically when a Vercel Blob store is connected to the project (including
## via the repo's "Deploy to Vercel" button). Takes priority over R2/S3 above when
## present — no action needed unless you're wiring this up outside of Vercel.
# BLOB_READ_WRITE_TOKEN=
