# ============================
# Database Configuration (SQLite by default, Postgres supported)
# ============================

## Zero config: with no DATABASE_URL set, the blog uses a local SQLite file at
## .aphex/blog.db (gitignored). Schema is pushed automatically on boot.
# DATABASE_URL="file:.aphex/blog.db"

## Turso-hosted SQLite (managed hosting):
# DATABASE_URL="libsql://your-db-name.turso.io"
# DATABASE_AUTH_TOKEN="your-turso-auth-token"

## Deploying on Vercel: connect a "Turso Cloud" store from the project's Storage tab
## instead — it injects TURSO_DATABASE_URL/TURSO_AUTH_TOKEN automatically, which this
## app reads as a fallback when DATABASE_URL isn't set. No manual copy-pasting needed.

## Postgres (e.g. Neon): set DATABASE_URL to a postgres:// or postgresql:// URL and
## the blog auto-switches dialect — same zero-config push-on-boot, no APHEX_DATABASE
## needed. This is what the repo's "Deploy to Vercel" button auto-provisions.
# DATABASE_URL="postgres://user:password@host/dbname"

## Force the dialect explicitly instead of relying on the DATABASE_URL sniff above:
# APHEX_DATABASE=postgres

# ============================
# Auth Configuration
# ============================
# BETTER_AUTH_SECRET / BETTER_AUTH_URL also work for backwards compatibility
BETTER_AUTH_SECRET=your-secret-key-here-change-in-production
BETTER_AUTH_URL=http://localhost:5173
AUTH_TRUSTED_ORIGINS=http://localhost:5173

## Email verification is OFF by default (self-hosted apps like Dokploy/WordPress
## don't force it, and it blocks the first signup without a deliverable SMTP/
## Mailpit server). Opt in for production by uncommenting the line below — without
## it, anyone can sign up with an address they don't own (and the first user
## becomes super admin).
# AUTH_REQUIRE_EMAIL_VERIFICATION=true

# ============================
# Resend Email Configuration (optional)
# ============================
RESEND_API_KEY=re_your_api_key_here

# ============================
# S3_COMPATIBLE CONFIGURATION (optional)
# ============================
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
# Optional: custom CDN domain (overrides R2_PUBLIC_URL for asset URLs)
# R2_CDN_URL=https://cdn.yourdomain.com

# ============================
# Vercel Blob Storage (optional)
# ============================
## Set automatically when a Vercel Blob store is connected to the project (including
## via the repo's "Deploy to Vercel" button). Takes priority over R2/S3 above when
## present — no action needed unless you're wiring this up outside of Vercel.
# BLOB_READ_WRITE_TOKEN=
